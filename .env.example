# Server Configuration
PORT=3000

# OpenAI API Key (Required for backend proxy usage)
# Get a key from OpenAI Platform dashboard: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Connection String (Required for chat storage)
# e.g., mongodb://localhost:27017/voice-bot or a MongoDB Atlas URI
MONGODB_URI=your_mongodb_connection_string_here

